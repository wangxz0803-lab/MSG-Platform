# MSG-Embedding 环境变量配置

# 项目根目录
MSG_REPO_ROOT=D:/MSG平台_cc

# 数据库（SQLite，Alembic 管理迁移）
MSG_DB_URL=sqlite:///msg.db

# Redis（Dramatiq broker）
MSG_REDIS_URL=redis://localhost:6379/0

# API 服务
MSG_API_PORT=8000
MSG_API_HOST=0.0.0.0

# 日志
MSG_LOG_LEVEL=INFO
MSG_LOG_FORMAT=console  # console | json

# 数据目录
MSG_DATA_DIR=data
MSG_ARTIFACTS_DIR=artifacts
MSG_REPORTS_DIR=reports
MSG_BRIDGE_OUT_DIR=bridge_out

# Worker
MSG_WORKER_PROCESSES=2
MSG_WORKER_THREADS=4
MSG_WORKER_POLL_INTERVAL=2.0
MSG_WORKER_TASK_TIMEOUT_HOURS=12.0

# 可选：MATLAB（QuaDRiGa 数据源）
# MSG_MATLAB_EXE=matlab

# 可选：CUDA
# CUDA_VISIBLE_DEVICES=0
