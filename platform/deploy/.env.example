# ChannelHub deploy configuration
# Copy to .env and edit for your host.

# Absolute path to the repo root on the host. On Windows use forward slashes.
MSG_REPO_PATH=D:/MSG平台_cc

# Redis password - CHANGE THIS in production. Leave blank to disable auth.
REDIS_PASSWORD=changeme

# Frontend build-time API base (baked into the static bundle).
VITE_API_BASE_URL=/api

# ---- GPU override ----------------------------------------------------------
# Used only when launching with docker-compose.gpu.yml.
CUDA_VISIBLE_DEVICES=0

# ---- Worker tuning ---------------------------------------------------------
WORKER_PROCESSES=2
WORKER_THREADS=4
