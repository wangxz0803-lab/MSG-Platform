{
  "type": "object",
  "title": "MSG-Embedding Configuration",
  "properties": {
    "project": {
      "type": "object",
      "title": "Project",
      "properties": {
        "name": {
          "type": "string",
          "default": "msg_embedding"
        },
        "version": {
          "type": "string",
          "default": "0.3.0-dev"
        },
        "seed": {
          "type": "integer",
          "default": 42
        }
      }
    },
    "data": {
      "type": "object",
      "title": "Data",
      "properties": {
        "tx_ant_num_min": {
          "type": "integer",
          "default": 4
        },
        "tx_ant_num_max": {
          "type": "integer",
          "default": 64
        },
        "ue_rx_ant_num_min": {
          "type": "integer",
          "default": 1
        },
        "ue_rx_ant_num_max": {
          "type": "integer",
          "default": 8
        },
        "ue_tx_ant_num_min": {
          "type": "integer",
          "default": 1
        },
        "ue_tx_ant_num_max": {
          "type": "integer",
          "default": 8
        },
        "flow_num": {
          "type": "integer",
          "default": 4
        },
        "cell_rsrp_dim": {
          "type": "integer",
          "default": 16
        },
        "reconstruction_features": {
          "type": "array",
          "default": [
            "pdp_crop",
            "srs1",
            "srs2",
            "srs3",
            "srs4",
            "pmi1",
            "pmi2",
            "pmi3",
            "pmi4",
            "dft1",
            "dft2",
            "dft3",
            "dft4",
            "rsrp_srs",
            "rsrp_cb",
            "cell_rsrp"
          ]
        }
      }
    },
    "data_sionna_rt": {
      "type": "object",
      "title": "Data (sionna_rt)",
      "properties": {
        "source": {
          "type": "string",
          "default": "sionna_rt"
        },
        "scenario": {
          "type": "string",
          "enum": ["munich", "etoile", "custom_osm"],
          "default": "munich"
        },
        "num_cells": {
          "type": "integer",
          "default": 7,
          "description": "Number of BS cells (legacy key; prefer num_sites)"
        },
        "num_sites": {
          "type": "integer",
          "default": 7,
          "description": "Number of BS sites (preferred over num_cells)"
        },
        "num_ues": {
          "type": "integer",
          "default": 50
        },
        "num_samples": {
          "type": "integer",
          "default": 100
        },
        "serving_cell_id": {
          "type": "integer",
          "default": 0
        },
        "isd_m": {
          "type": "number",
          "default": 500.0,
          "description": "Inter-site distance in metres"
        },
        "sectors_per_site": {
          "type": "integer",
          "enum": [1, 3],
          "default": 3,
          "description": "1 (omni) or 3 (tri-sector)"
        },
        "tx_height_m": {
          "type": "number",
          "default": 25.0,
          "description": "BS antenna height in metres"
        },
        "carrier_freq_hz": {
          "type": "number",
          "default": 3500000000.0,
          "description": "Carrier frequency in Hz"
        },
        "bandwidth_hz": {
          "type": "number",
          "default": 100000000.0,
          "description": "System bandwidth in Hz"
        },
        "fft_size": {
          "type": "integer",
          "default": 1024
        },
        "num_ofdm_symbols": {
          "type": "integer",
          "default": 14
        },
        "subcarrier_spacing": {
          "type": "number",
          "default": 30000.0,
          "description": "Subcarrier spacing in Hz"
        },
        "num_bs_ant": {
          "type": "integer",
          "default": 4,
          "description": "Legacy BS antenna count (backward compat)"
        },
        "num_ue_ant": {
          "type": "integer",
          "default": 2,
          "description": "Legacy UE antenna count (backward compat)"
        },
        "num_bs_tx_ant": {
          "type": "integer",
          "default": 64,
          "description": "BS transmit antennas"
        },
        "num_bs_rx_ant": {
          "type": "integer",
          "default": 64,
          "description": "BS receive antennas"
        },
        "num_ue_tx_ant": {
          "type": "integer",
          "default": 2,
          "description": "UE transmit antennas"
        },
        "num_ue_rx_ant": {
          "type": "integer",
          "default": 4,
          "description": "UE receive antennas"
        },
        "tx_power_dbm": {
          "type": ["number", "null"],
          "default": null,
          "description": "BS transmit power in dBm. If null, auto-selects per scenario: UMa=43, UMi=33, InF=24 dBm"
        },
        "ue_speed_kmh": {
          "type": "number",
          "default": 3.0,
          "description": "UE mobility speed in km/h"
        },
        "ue_distribution": {
          "type": "string",
          "enum": ["uniform", "clustered", "hotspot"],
          "default": "uniform",
          "description": "UE spatial distribution strategy"
        },
        "pilot_type": {
          "type": "string",
          "enum": ["srs_zc", "csi_rs_gold"],
          "default": "csi_rs_gold"
        },
        "pilot_type_dl": {
          "type": "string",
          "enum": ["srs_zc", "csi_rs_gold"],
          "default": "csi_rs_gold",
          "description": "DL pilot type (used when link == both)"
        },
        "pilot_type_ul": {
          "type": "string",
          "enum": ["srs_zc", "csi_rs_gold"],
          "default": "srs_zc",
          "description": "UL pilot type (used when link == both)"
        },
        "channel_est_mode": {
          "type": "string",
          "enum": ["ideal", "ls_linear", "ls_mmse"],
          "default": "ls_linear"
        },
        "link": {
          "type": "string",
          "enum": ["UL", "DL", "both"],
          "default": "DL"
        },
        "device": {
          "type": "string",
          "enum": ["cpu", "cuda"],
          "default": "cuda"
        },
        "custom_site_positions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            },
            "required": ["x", "y"]
          },
          "description": "Custom BS positions from frontend drag-and-drop"
        },
        "custom_ue_positions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            },
            "required": ["x", "y"]
          },
          "description": "Custom UE positions from frontend drag-and-drop"
        }
      }
    },
    "eval": {
      "type": "object",
      "title": "Eval",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": false
        }
      }
    },
    "infer": {
      "type": "object",
      "title": "Infer",
      "properties": {
        "enabled": {
          "type": "boolean",
          "default": true
        },
        "ckpt": {
          "type": "string",
          "default": ""
        },
        "input": {
          "type": "string",
          "default": ""
        },
        "output": {
          "type": "string",
          "default": ""
        },
        "batch_size": {
          "type": "integer",
          "default": 64
        },
        "num_workers": {
          "type": "integer",
          "default": 0
        },
        "device": {
          "type": "string",
          "default": "cpu"
        },
        "half": {
          "type": "boolean",
          "default": false
        },
        "use_adapter": {
          "type": "boolean",
          "default": false
        },
        "glob": {
          "type": "string",
          "default": "*.pt"
        },
        "export": {
          "type": "object",
          "properties": {
            "ckpt": {
              "type": "string",
              "default": ""
            },
            "output_dir": {
              "type": "string",
              "default": ""
            },
            "opset": {
              "type": "integer",
              "default": 17
            },
            "dynamic_batch": {
              "type": "boolean",
              "default": true
            },
            "validate": {
              "type": "boolean",
              "default": true
            },
            "emit_onnx": {
              "type": "boolean",
              "default": true
            },
            "emit_torchscript": {
              "type": "boolean",
              "default": true
            },
            "torchscript_method": {
              "type": "string",
              "default": "trace"
            },
            "use_adapter": {
              "type": "boolean",
              "default": false
            }
          }
        }
      }
    },
    "model": {
      "type": "object",
      "title": "Model",
      "properties": {
        "seq_len": {
          "type": "integer",
          "default": 16,
          "description": "Token sequence length (fixed at 16 for standard MSG tokenization)"
        },
        "token_dim": {
          "type": "integer",
          "default": 128,
          "description": "Per-token embedding dimension (must be divisible by n_heads)"
        },
        "latent_dim": {
          "type": "integer",
          "default": 256,
          "description": "Bottleneck / latent channel dimension"
        },
        "n_heads": {
          "type": "integer",
          "default": 8,
          "description": "Attention heads (4/8/16; must divide token_dim)"
        },
        "encoder_layers": {
          "type": "integer",
          "default": 4,
          "description": "Encoder Transformer depth (4/6/8; increase for larger data)"
        },
        "decoder_layers": {
          "type": "integer",
          "default": 2,
          "description": "Decoder Transformer depth (typically encoder_layers // 2)"
        },
        "ff_dim": {
          "type": "integer",
          "default": 512,
          "description": "Feed-forward hidden dim (recommended 2x~4x token_dim)"
        },
        "dropout_p": {
          "type": "number",
          "default": 0.1,
          "description": "Dropout rate (increase to ~0.2 for small datasets)"
        },
        "mask_ratio": {
          "type": "number",
          "default": 0.3,
          "description": "Base MAE mask ratio for evaluation"
        },
        "mask_ratio_v2": {
          "type": "number",
          "default": 0.2,
          "description": "Alternate mask ratio for v2 path"
        },
        "latent_out_dim": {
          "type": "integer",
          "default": 16,
          "description": "Final latent projection dimension"
        },
        "use_ground_truth_for_recon": {
          "type": "boolean",
          "default": true,
          "description": "Use ground truth as decoder teacher forcing target"
        },
        "norm_eps": {
          "type": "number",
          "default": 1e-08,
          "description": "LayerNorm / BatchNorm epsilon"
        }
      }
    },
    "train": {
      "type": "object",
      "title": "Train",
      "properties": {
        "epochs": {
          "type": "integer",
          "default": 20,
          "description": "Total training epochs (20=smoke test; production: 100+)"
        },
        "warmup_epochs": {
          "type": "integer",
          "default": 3,
          "description": "Linear LR warmup span"
        },
        "batch_size": {
          "type": "integer",
          "default": 32,
          "description": "Per-device batch size"
        },
        "gradient_accumulation_steps": {
          "type": "integer",
          "default": 2,
          "description": "Effective batch = batch_size × this value"
        },
        "learning_rate": {
          "type": "number",
          "default": 0.0001,
          "description": "Peak learning rate after warmup"
        },
        "min_learning_rate": {
          "type": "number",
          "default": 1e-06,
          "description": "Floor for cosine decay"
        },
        "early_stop_patience": {
          "type": "integer",
          "default": 15,
          "description": "Epochs without val-loss improvement before stopping"
        },
        "val_split": {
          "type": "number",
          "default": 0.1,
          "description": "Fraction of data held out for validation"
        },
        "use_snr_condition": {
          "type": "boolean",
          "default": true,
          "description": "Condition encoder on SNR metadata"
        },
        "use_feature_weighting": {
          "type": "boolean",
          "default": true,
          "description": "Apply per-feature loss weights (see recon_weights)"
        },
        "use_multi_scale_mask": {
          "type": "boolean",
          "default": true,
          "description": "Cycle through mask_ratios during training"
        },
        "mask_ratios": {
          "type": "array",
          "default": [
            0.15,
            0.3,
            0.5
          ],
          "description": "Multi-scale mask schedule [stage1, stage2, stage3]"
        },
        "recon_weights": {
          "type": "object",
          "description": "Per-feature reconstruction loss weights (higher = more important)",
          "properties": {
            "pdp_crop": {
              "type": "number",
              "default": 1.0
            },
            "srs1": {
              "type": "number",
              "default": 2.0
            },
            "srs2": {
              "type": "number",
              "default": 2.0
            },
            "srs3": {
              "type": "number",
              "default": 2.0
            },
            "srs4": {
              "type": "number",
              "default": 2.0
            },
            "pmi1": {
              "type": "number",
              "default": 1.5
            },
            "pmi2": {
              "type": "number",
              "default": 1.5
            },
            "pmi3": {
              "type": "number",
              "default": 1.5
            },
            "pmi4": {
              "type": "number",
              "default": 1.5
            },
            "dft1": {
              "type": "number",
              "default": 1.0
            },
            "dft2": {
              "type": "number",
              "default": 1.0
            },
            "dft3": {
              "type": "number",
              "default": 1.0
            },
            "dft4": {
              "type": "number",
              "default": 1.0
            },
            "rsrp_srs": {
              "type": "number",
              "default": 1.0
            },
            "rsrp_cb": {
              "type": "number",
              "default": 1.0
            },
            "cell_rsrp": {
              "type": "number",
              "default": 0.5
            }
          }
        },
        "perturb_gauss": {
          "type": "number",
          "default": 0.001,
          "description": "Additive Gaussian noise std for dual-view augmentation"
        },
        "perturb_scale": {
          "type": "number",
          "default": 0.05,
          "description": "Multiplicative scale jitter magnitude"
        },
        "perturb_shift": {
          "type": "number",
          "default": 0.02,
          "description": "Additive bias jitter magnitude"
        },
        "online": {
          "type": "object",
          "properties": {
            "epochs": {
              "type": "integer",
              "default": 15,
              "description": "Online adaptation epochs"
            },
            "learning_rate": {
              "type": "number",
              "default": 5e-05,
              "description": "Online adaptation learning rate"
            },
            "use_adapter": {
              "type": "boolean",
              "default": true,
              "description": "Enable LoRA-style adapter layers"
            },
            "use_regularization": {
              "type": "boolean",
              "default": true,
              "description": "Anchor toward pre-trained weights (EWC-like)"
            }
          }
        },
        "loss_weight_schedule": {
          "type": "array",
          "description": "Loss weight phases: each item is [end_fraction, recon_weight, contrastive_weight]",
          "default": [[0.1, 1.5, 0.2], [0.3, 1.0, 0.5], [1.0, 0.8, 1.0]],
          "items": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          }
        }
      }
    }
  }
}