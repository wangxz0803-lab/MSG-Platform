{
  "type": "object",
  "title": "ChannelHub Configuration",
  "properties": {
    "project": {
      "type": "object",
      "title": "Project",
      "properties": {
        "name": {
          "type": "string",
          "default": "msg_embedding"
        },
        "version": {
          "type": "string",
          "default": "0.3.0-dev"
        },
        "seed": {
          "type": "integer",
          "default": 42
        }
      }
    },
    "data": {
      "type": "object",
      "title": "Data",
      "properties": {
        "tx_ant_num_min": {
          "type": "integer",
          "default": 4
        },
        "tx_ant_num_max": {
          "type": "integer",
          "default": 64
        },
        "ue_rx_ant_num_min": {
          "type": "integer",
          "default": 1
        },
        "ue_rx_ant_num_max": {
          "type": "integer",
          "default": 8
        },
        "ue_tx_ant_num_min": {
          "type": "integer",
          "default": 1
        },
        "ue_tx_ant_num_max": {
          "type": "integer",
          "default": 8
        },
        "flow_num": {
          "type": "integer",
          "default": 4
        },
        "cell_rsrp_dim": {
          "type": "integer",
          "default": 16
        },
        "reconstruction_features": {
          "type": "array",
          "default": [
            "pdp_crop",
            "srs1",
            "srs2",
            "srs3",
            "srs4",
            "pmi1",
            "pmi2",
            "pmi3",
            "pmi4",
            "dft1",
            "dft2",
            "dft3",
            "dft4",
            "rsrp_srs",
            "rsrp_cb",
            "cell_rsrp"
          ]
        }
      }
    },
    "data_sionna_rt": {
      "type": "object",
      "title": "Data (sionna_rt)",
      "properties": {
        "source": {
          "type": "string",
          "default": "sionna_rt"
        },
        "scenario": {
          "type": "string",
          "enum": ["munich", "etoile", "custom_osm"],
          "default": "munich"
        },
        "num_cells": {
          "type": "integer",
          "default": 7,
          "description": "Number of BS cells (legacy key; prefer num_sites)"
        },
        "num_sites": {
          "type": "integer",
          "default": 7,
          "description": "Number of BS sites (preferred over num_cells)"
        },
        "num_ues": {
          "type": "integer",
          "default": 50
        },
        "num_interfering_ues": {
          "type": "integer",
          "default": 3,
          "description": "Number of interfering UEs per cell for interference estimation"
        },
        "num_samples": {
          "type": "integer",
          "default": 100
        },
        "serving_cell_id": {
          "type": "integer",
          "default": 0
        },
        "isd_m": {
          "type": "number",
          "default": 500.0,
          "description": "Inter-site distance in metres"
        },
        "sectors_per_site": {
          "type": "integer",
          "enum": [1, 3],
          "default": 3,
          "description": "1 (omni) or 3 (tri-sector)"
        },
        "tx_height_m": {
          "type": "number",
          "default": 25.0,
          "description": "BS antenna height in metres"
        },
        "carrier_freq_hz": {
          "type": "number",
          "default": 3500000000.0,
          "description": "Carrier frequency in Hz"
        },
        "bandwidth_hz": {
          "type": "number",
          "enum": [5000000, 10000000, 15000000, 20000000, 25000000, 30000000, 40000000, 50000000, 60000000, 70000000, 80000000, 90000000, 100000000],
          "default": 100000000,
          "description": "System bandwidth in Hz (NR FR1 standard values)"
        },
        "fft_size": {
          "type": "integer",
          "default": 1024
        },
        "num_ofdm_symbols": {
          "type": "integer",
          "default": 14
        },
        "subcarrier_spacing": {
          "type": "number",
          "enum": [15000, 30000, 60000, 120000],
          "default": 30000,
          "description": "Subcarrier spacing in Hz (15/30/60/120 kHz per 3GPP NR)"
        },
        "num_bs_ant": {
          "type": "integer",
          "default": 4,
          "description": "Legacy BS antenna count (backward compat)"
        },
        "num_ue_ant": {
          "type": "integer",
          "default": 2,
          "description": "Legacy UE antenna count (backward compat)"
        },
        "num_bs_tx_ant": {
          "type": "integer",
          "default": 64,
          "description": "BS transmit antennas"
        },
        "num_bs_rx_ant": {
          "type": "integer",
          "default": 64,
          "description": "BS receive antennas"
        },
        "num_ue_tx_ant": {
          "type": "integer",
          "default": 2,
          "description": "UE transmit antennas"
        },
        "num_ue_rx_ant": {
          "type": "integer",
          "default": 4,
          "description": "UE receive antennas"
        },
        "tx_power_dbm": {
          "type": ["number", "null"],
          "default": null,
          "description": "BS transmit power in dBm. If null, auto-selects per scenario: UMa=43, UMi=33, InF=24 dBm"
        },
        "ue_speed_kmh": {
          "type": "number",
          "default": 3.0,
          "description": "UE mobility speed in km/h"
        },
        "ue_distribution": {
          "type": "string",
          "enum": ["uniform", "clustered", "hotspot"],
          "default": "uniform",
          "description": "UE spatial distribution strategy"
        },
        "pilot_type": {
          "type": "string",
          "enum": ["srs_zc", "csi_rs_gold"],
          "default": "csi_rs_gold"
        },
        "pilot_type_dl": {
          "type": "string",
          "enum": ["srs_zc", "csi_rs_gold"],
          "default": "csi_rs_gold",
          "description": "DL pilot type (used when link == both)"
        },
        "pilot_type_ul": {
          "type": "string",
          "enum": ["srs_zc", "csi_rs_gold"],
          "default": "srs_zc",
          "description": "UL pilot type (used when link == both)"
        },
        "channel_est_mode": {
          "type": "string",
          "enum": ["ideal", "ls_linear", "ls_mmse"],
          "default": "ls_linear"
        },
        "link": {
          "type": "string",
          "enum": ["UL", "DL", "both"],
          "default": "DL"
        },
        "device": {
          "type": "string",
          "enum": ["cpu", "cuda"],
          "default": "cuda"
        },
        "custom_site_positions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            },
            "required": ["x", "y"]
          },
          "description": "Custom BS positions from frontend drag-and-drop"
        },
        "custom_ue_positions": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "x": { "type": "number" },
              "y": { "type": "number" },
              "z": { "type": "number" }
            },
            "required": ["x", "y"]
          },
          "description": "Custom UE positions from frontend drag-and-drop"
        },
        "tdd_pattern": {
          "type": "string",
          "enum": ["DDDSU", "DDSUU", "DDDDDDDSUU", "DDDSUDDSUU", "DSUUD"],
          "default": "DDDSU",
          "description": "TDD slot pattern per 3GPP TS 38.213 §11.1"
        },
        "srs_periodicity": {
          "type": "integer",
          "enum": [1, 2, 4, 5, 8, 10, 16, 20, 32, 40, 64, 80, 160, 320, 640, 1280, 2560],
          "default": 10,
          "description": "SRS transmission periodicity in slots (3GPP TS 38.211 Table 6.4.1.4.4-1)"
        },
        "srs_group_hopping": {
          "type": "boolean",
          "default": false,
          "description": "Enable SRS group hopping (mutually exclusive with sequence hopping)"
        },
        "srs_sequence_hopping": {
          "type": "boolean",
          "default": false,
          "description": "Enable SRS sequence hopping (mutually exclusive with group hopping)"
        },
        "srs_comb": {
          "type": "integer",
          "enum": [2, 4, 8],
          "default": 2,
          "description": "SRS transmission comb K_TC per 3GPP TS 38.211 §6.4.1.4.2"
        },
        "srs_c_srs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 17,
          "default": 3,
          "description": "SRS bandwidth configuration index (38.211 Table 6.4.1.4.3-1), determines total SRS allocation and hopping tree"
        },
        "srs_b_srs": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3,
          "default": 1,
          "description": "SRS bandwidth level (38.211 §6.4.1.4.3), higher value = narrower single-TX bandwidth, more hopping positions"
        },
        "srs_n_rrc": {
          "type": "integer",
          "minimum": 0,
          "default": 0,
          "description": "RRC-configured SRS frequency-domain starting RB position (38.211 §6.4.1.4.3)"
        },
        "srs_b_hop": {
          "type": "integer",
          "minimum": 0,
          "maximum": 3,
          "default": 0,
          "description": "SRS frequency hopping parameter (38.211 §6.4.1.4.3), b_hop < B_SRS enables hopping"
        }
      }
    },
