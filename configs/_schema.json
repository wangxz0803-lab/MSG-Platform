          "default": false
        },
        "glob": {
          "type": "string",
          "default": "*.pt"
        },
        "export": {
          "type": "object",
          "properties": {
            "ckpt": {
              "type": "string",
              "default": ""
            },
            "output_dir": {
              "type": "string",
              "default": ""
            },
            "opset": {
              "type": "integer",
              "default": 17
            },
            "dynamic_batch": {
              "type": "boolean",
              "default": true
            },
            "validate": {
              "type": "boolean",
              "default": true
            },
            "emit_onnx": {
              "type": "boolean",
              "default": true
            },
            "emit_torchscript": {
              "type": "boolean",
              "default": true
            },
            "torchscript_method": {
              "type": "string",
              "default": "trace"
            },
            "use_adapter": {
              "type": "boolean",
              "default": false
            }
          }
        }
      }
    },
    "model": {
      "type": "object",
      "title": "Model",
      "properties": {
        "seq_len": {
          "type": "integer",
          "default": 16,
          "description": "Token sequence length (fixed at 16 for standard MSG tokenization)"
        },
        "token_dim": {
          "type": "integer",
          "default": 128,
          "description": "Per-token embedding dimension (must be divisible by n_heads)"
        },
        "latent_dim": {
          "type": "integer",
          "default": 256,
          "description": "Bottleneck / latent channel dimension"
        },
        "n_heads": {
          "type": "integer",
          "default": 8,
          "description": "Attention heads (4/8/16; must divide token_dim)"
        },
        "encoder_layers": {
          "type": "integer",
          "default": 4,
          "description": "Encoder Transformer depth (4/6/8; increase for larger data)"
        },
        "decoder_layers": {
          "type": "integer",
          "default": 2,
          "description": "Decoder Transformer depth (typically encoder_layers // 2)"
        },
        "ff_dim": {
          "type": "integer",
          "default": 512,
          "description": "Feed-forward hidden dim (recommended 2x~4x token_dim)"
        },
        "dropout_p": {
          "type": "number",
          "default": 0.1,
          "description": "Dropout rate (increase to ~0.2 for small datasets)"
        },
        "mask_ratio": {
          "type": "number",
          "default": 0.3,
          "description": "Base MAE mask ratio for evaluation"
        },
        "mask_ratio_v2": {
          "type": "number",
          "default": 0.2,
          "description": "Alternate mask ratio for v2 path"
        },
        "latent_out_dim": {
          "type": "integer",
          "default": 16,
          "description": "Final latent projection dimension"
        },
        "use_ground_truth_for_recon": {
          "type": "boolean",
          "default": true,
          "description": "Use ground truth as decoder teacher forcing target"
        },
        "norm_eps": {
          "type": "number",
          "default": 1e-08,
          "description": "LayerNorm / BatchNorm epsilon"
        }
      }
    },
    "train": {
      "type": "object",
      "title": "Train",
      "properties": {
        "epochs": {
          "type": "integer",
          "default": 20,
          "description": "Total training epochs (20=smoke test; production: 100+)"
        },
        "warmup_epochs": {
          "type": "integer",
          "default": 3,
          "description": "Linear LR warmup span"
        },
        "batch_size": {
          "type": "integer",
          "default": 32,
          "description": "Per-device batch size"
        },
        "gradient_accumulation_steps": {
          "type": "integer",
          "default": 2,
          "description": "Effective batch = batch_size × this value"
        },
        "learning_rate": {
          "type": "number",
          "default": 0.0001,
          "description": "Peak learning rate after warmup"
        },
        "min_learning_rate": {
          "type": "number",
          "default": 1e-06,
          "description": "Floor for cosine decay"
        },
        "early_stop_patience": {
          "type": "integer",
          "default": 15,
          "description": "Epochs without val-loss improvement before stopping"
        },
        "val_split": {
          "type": "number",
          "default": 0.1,
          "description": "Fraction of data held out for validation"
        },
        "use_snr_condition": {
          "type": "boolean",
          "default": true,
          "description": "Condition encoder on SNR metadata"
        },
        "use_feature_weighting": {
          "type": "boolean",
          "default": true,
          "description": "Apply per-feature loss weights (see recon_weights)"
        },
        "use_multi_scale_mask": {
          "type": "boolean",
          "default": true,
          "description": "Cycle through mask_ratios during training"
        },
        "mask_ratios": {
          "type": "array",
          "default": [
            0.15,
            0.3,
            0.5
          ],
          "description": "Multi-scale mask schedule [stage1, stage2, stage3]"
        },
        "recon_weights": {
          "type": "object",
          "description": "Per-feature reconstruction loss weights (higher = more important)",
          "properties": {
            "pdp_crop": {
              "type": "number",
              "default": 1.0
            },
            "srs1": {
              "type": "number",
              "default": 2.0
            },
            "srs2": {
              "type": "number",
              "default": 2.0
            },
            "srs3": {
              "type": "number",
              "default": 2.0
            },
            "srs4": {
              "type": "number",
              "default": 2.0
            },
            "pmi1": {
              "type": "number",
              "default": 1.5
            },
            "pmi2": {
              "type": "number",
              "default": 1.5
            },
            "pmi3": {
              "type": "number",
              "default": 1.5
            },
            "pmi4": {
              "type": "number",
              "default": 1.5
            },
            "dft1": {
              "type": "number",
              "default": 1.0
            },
            "dft2": {
              "type": "number",
              "default": 1.0
            },
            "dft3": {
              "type": "number",
              "default": 1.0
            },
            "dft4": {
              "type": "number",
              "default": 1.0
            },
            "rsrp_srs": {
              "type": "number",
              "default": 1.0
            },
            "rsrp_cb": {
              "type": "number",
              "default": 1.0
            },
            "cell_rsrp": {
              "type": "number",
              "default": 0.5
            }
          }
        },
        "perturb_gauss": {
          "type": "number",
          "default": 0.001,
          "description": "Additive Gaussian noise std for dual-view augmentation"
        },
        "perturb_scale": {
          "type": "number",
          "default": 0.05,
          "description": "Multiplicative scale jitter magnitude"
        },
        "perturb_shift": {
          "type": "number",
          "default": 0.02,
          "description": "Additive bias jitter magnitude"
        },
        "online": {
          "type": "object",
          "properties": {
            "epochs": {
              "type": "integer",
              "default": 15,
              "description": "Online adaptation epochs"
            },
            "learning_rate": {
              "type": "number",
              "default": 5e-05,
              "description": "Online adaptation learning rate"
            },
            "use_adapter": {
              "type": "boolean",
              "default": true,
              "description": "Enable LoRA-style adapter layers"
            },
            "use_regularization": {
              "type": "boolean",
              "default": true,
              "description": "Anchor toward pre-trained weights (EWC-like)"
            }
          }
        },
        "loss_weight_schedule": {
          "type": "array",
          "description": "Loss weight phases: each item is [end_fraction, recon_weight, contrastive_weight]",
          "default": [[0.1, 1.5, 0.2], [0.3, 1.0, 0.5], [1.0, 0.8, 1.0]],
          "items": {
            "type": "array",
            "items": { "type": "number" },
            "minItems": 3,
            "maxItems": 3
          }
        }
      }
    }
  }
}