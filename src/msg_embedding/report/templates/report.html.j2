<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<title>ChannelHub report - {{ run_id }}</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
         max-width: 1100px; margin: 2em auto; padding: 0 1.5em; color: #222; }
  h1, h2 { border-bottom: 1px solid #ddd; padding-bottom: 0.3em; }
  table { border-collapse: collapse; width: 100%; margin-top: 0.5em; }
  th, td { border: 1px solid #ddd; padding: 0.4em 0.6em; text-align: left; font-size: 0.92em; }
  th { background-color: #f6f8fa; }
  .meta-line { color: #555; font-size: 0.92em; margin: 0.2em 0; }
  .section { margin-top: 2em; }
  .notes { background: #fff8e1; border: 1px solid #ffe082; padding: 0.8em; margin-top: 1em;
           border-radius: 4px; font-size: 0.9em; }
  .placeholder { color: #777; font-style: italic; }
  footer { margin-top: 3em; color: #888; font-size: 0.85em; border-top: 1px solid #ddd;
           padding-top: 0.6em; }
  pre { background: #f6f8fa; padding: 0.6em; overflow-x: auto; font-size: 0.85em; }
</style>
</head>
<body>

<h1>ChannelHub run: {{ run_id }}</h1>
<p class="meta-line"><strong>timestamp:</strong> {{ timestamp }}</p>
<p class="meta-line"><strong>git_sha:</strong> {{ git_sha }}</p>
<p class="meta-line"><strong>ckpt:</strong> {{ ckpt_path }}</p>

<div class="section">
  <h2>1. Hyperparameters</h2>
  {% if config_table %}
  <table>
    <thead><tr><th>key</th><th>value</th></tr></thead>
    <tbody>
    {% for key, value in config_table %}
      <tr><td>{{ key }}</td><td>{{ value }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  {% else %}
  <p class="placeholder">No config.yaml available for this run.</p>
  {% endif %}
</div>

<div class="section">
  <h2>2. Training curves</h2>
  {% if training_curves_html %}
    {{ training_curves_html | safe }}
  {% else %}
    <p class="placeholder">Training curves unavailable (missing tb/ or plotly).</p>
  {% endif %}
</div>

<div class="section">
  <h2>3. Metrics</h2>
  {% if metrics_rows %}
  <table>
    <thead><tr><th>metric</th><th>value</th></tr></thead>
    <tbody>
    {% for label, value in metrics_rows %}
      <tr><td>{{ label }}</td><td>{{ value }}</td></tr>
    {% endfor %}
    </tbody>
  </table>
  {% else %}
    <p class="placeholder">No metrics.json available for this run.</p>
  {% endif %}
</div>

<div class="section">
  <h2>4. Latent UMAP</h2>
  {% if latent_html %}
    {{ latent_html | safe }}
  {% else %}
    <p class="placeholder">No embeddings.parquet available for this run.</p>
  {% endif %}
</div>

<div class="section">
  <h2>5. Dataset statistics</h2>
  {% if dataset_summary %}
    <p class="meta-line">rows in manifest: {{ dataset_summary.n_rows }}</p>
    {% if dataset_summary.source_counts %}
    <h3>source breakdown</h3>
    <table>
      <thead><tr><th>source</th><th>count</th></tr></thead>
      <tbody>
      {% for key, value in dataset_summary.source_counts.items() %}
        <tr><td>{{ key }}</td><td>{{ value }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
    {% endif %}
    {% if dataset_summary.split_counts %}
    <h3>split breakdown</h3>
    <table>
      <thead><tr><th>split</th><th>count</th></tr></thead>
      <tbody>
      {% for key, value in dataset_summary.split_counts.items() %}
        <tr><td>{{ key }}</td><td>{{ value }}</td></tr>
      {% endfor %}
      </tbody>
    </table>
    {% endif %}
    {% if dataset_summary.histogram_png %}
      <p><img src="{{ dataset_summary.histogram_png }}" alt="manifest histograms" style="max-width:100%;"/></p>
    {% endif %}
  {% else %}
    <p class="placeholder">No manifest.parquet available.</p>
  {% endif %}
</div>

{% if notes %}
<div class="notes">
  <strong>Generator notes</strong>
  <ul>
  {% for note in notes %}
    <li>{{ note }}</li>
  {% endfor %}
  </ul>
</div>
{% endif %}

<footer>Generated by msg_embedding Phase 4</footer>

</body>
</html>
