<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8"/>
<title>ChannelHub compare report</title>
<style>
  body { font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
         max-width: 1200px; margin: 2em auto; padding: 0 1.5em; color: #222; }
  h1, h2 { border-bottom: 1px solid #ddd; padding-bottom: 0.3em; }
  table { border-collapse: collapse; width: 100%; margin-top: 0.5em; }
  th, td { border: 1px solid #ddd; padding: 0.4em 0.6em; text-align: left; font-size: 0.92em; }
  th { background-color: #f6f8fa; }
  .placeholder { color: #777; font-style: italic; }
  footer { margin-top: 3em; color: #888; font-size: 0.85em; border-top: 1px solid #ddd;
           padding-top: 0.6em; }
</style>
</head>
<body>

<h1>ChannelHub multi-run comparison</h1>
<p><strong>runs compared:</strong>
  {% for rid in run_ids %}<code>{{ rid }}</code>{% if not loop.last %}, {% endif %}{% endfor %}
</p>

<h2>Metrics</h2>
<table>
  <thead>
    <tr>
      <th>metric</th>
      {% for rid in run_ids %}<th>{{ rid }}</th>{% endfor %}
    </tr>
  </thead>
  <tbody>
  {% for label, cells in metric_rows %}
    <tr>
      <td>{{ label }}</td>
      {% for c in cells %}<td>{{ c }}</td>{% endfor %}
    </tr>
  {% endfor %}
  </tbody>
</table>

<h2>Training curve overlay</h2>
{% if training_curves_html %}
  {{ training_curves_html | safe }}
{% else %}
  <p class="placeholder">No overlaid training curves available.</p>
{% endif %}

<footer>Generated by msg_embedding Phase 4</footer>

</body>
</html>
